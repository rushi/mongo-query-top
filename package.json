{
    "name": "mongo-query-top",
    "version": "1.0.0",
    "private": true,
    "repository": "https://github.com/rushi/mongo-query-top",
    "description": "Show the current operations on a MongoDB instance in an easy to read table",
    "type": "module",
    "packageManager": "pnpm@10.8.0",
    "workspaces": ["apps/*", "packages/*"],
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "dev:api": "turbo dev --filter=@mongo-query-top/api",
        "dev:cli": "turbo dev --filter=@mongo-query-top/cli",
        "dev:web": "turbo dev --filter=@mongo-query-top/web --filter=@mongo-query-top/api",
        "start:api": "pnpm --filter=@mongo-query-top/api start",
        "start:cli": "pnpm --filter=@mongo-query-top/cli start",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
        "lint": "turbo lint",
        "clean": "turbo clean && rm -rf node_modules"
    },
    "keywords": [
        "mongodb",
        "top"
    ],
    "author": "Rushi Vishavadia <rushi@hey.com>",
    "license": "MIT",
    "devDependencies": {
        "@fastify/cors": "^11.2.0",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
        "@types/geoip-lite": "^1.4.4",
        "@types/humanize-duration": "^3.27.4",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^25.0.3",
        "@types/yargs": "^17.0.35",
        "@typescript-eslint/eslint-plugin": "^8.51.0",
        "@typescript-eslint/parser": "^8.51.0",
        "chalk": "^5.6.2",
        "cli-table3": "^0.6.5",
        "concurrently": "^9.2.1",
        "dayjs": "^1.11.19",
        "dotenv": "^17.2.3",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "fastify": "^5.6.2",
        "geoip-lite": "^1.4.10",
        "humanize-duration": "^3.33.2",
        "json-stringify-pretty-compact": "^4.0.0",
        "lodash-es": "^4.17.22",
        "mongodb": "^7.0.0",
        "prettier": "^3.7.4",
        "tsx": "^4.21.0",
        "turbo": "^2.7.2",
        "typescript": "^5.9.3",
        "window-size": "^1.1.1",
        "yargs": "^18.0.0"
    }
}
