{
    "name": "mongo-query-top",
    "version": "1.0.0",
    "repository": "https://github.com/rushi/mongo-query-top",
    "description": "Show the current operations on a MongoDB instance in an easy to read table",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev:cli": "tsx watch src/app.ts",
        "dev:api": "tsx watch src/server.ts",
        "dev": "concurrently \"pnpm run dev:cli\" \"pnpm run dev:api\"",
        "build": "tsc",
        "start:cli": "node dist/app.js",
        "start:api": "node dist/server.js",
        "format": "prettier --write -l src",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix"
    },
    "keywords": [
        "mongodb",
        "top"
    ],
    "author": "Rushi Vishavadia <rushi@hey.com>",
    "license": "MIT",
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "chalk": "^5.6.2",
        "cli-table3": "^0.6.5",
        "dayjs": "^1.11.19",
        "dotenv": "^17.2.3",
        "fastify": "^5.6.2",
        "geoip-lite": "^1.4.10",
        "humanize-duration": "^3.33.2",
        "json-stringify-pretty-compact": "^4.0.0",
        "lodash-es": "^4.17.22",
        "mongodb": "^7.0.0",
        "prettier": "^3.7.4",
        "window-size": "^1.1.1",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@types/geoip-lite": "^1.4.4",
        "@types/humanize-duration": "^3.27.4",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^25.0.3",
        "@types/yargs": "^17.0.35",
        "@typescript-eslint/eslint-plugin": "^8.51.0",
        "@typescript-eslint/parser": "^8.51.0",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
