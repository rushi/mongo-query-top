{
    "name": "mongo-query-top",
    "version": "1.0.0",
    "private": true,
    "repository": "https://github.com/rushi/mongo-query-top",
    "description": "Show the current operations on a MongoDB instance in an easy to read table",
    "type": "module",
    "packageManager": "pnpm@10.8.0",
    "engines": {
        "node": ">=24.0.0"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "NODE_ENV=production node scripts/generate-web-config.js && turbo build --force",
        "dev": "turbo dev --filter=@mongo-query-top/web --filter=@mongo-query-top/api",
        "dev:api": "turbo dev --filter=@mongo-query-top/api",
        "start": "concurrently \"pnpm start:api\" \"pnpm start:web\"",
        "start:api": "pnpm --filter=@mongo-query-top/api start",
        "start:web": "pnpm --filter=@mongo-query-top/web start",
        "format": "prettier -l --write \"**/*.{ts,tsx,json,md}\"",
        "lint": "turbo lint",
        "clean": "turbo clean && rm -rf node_modules",
        "generate-web-config": "node scripts/generate-web-config.js",
        "docker:build": "bash scripts/docker-build.sh"
    },
    "keywords": [
        "mongo",
        "mongodb",
        "mongotop",
        "mongostat",
        "top"
    ],
    "author": "Rushi Vishavadia <rushi@hey.com>",
    "license": "MIT",
    "dependencies": {
        "config": "^4.4.2"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/node": "^24.13.2",
        "@typescript-eslint/eslint-plugin": "^8.62.1",
        "@typescript-eslint/parser": "^8.62.1",
        "concurrently": "^9.2.3",
        "eslint": "^9.39.4",
        "eslint-plugin-eslint-comments": "^3.2.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-no-use-extend-native": "^0.7.3",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-unicorn": "^64.0.0",
        "prettier": "^3.9.4",
        "prettier-plugin-tailwindcss": "^0.7.4",
        "turbo": "^2.10.3",
        "typescript": "^5.9.3"
    },
    "pnpm": {
        "overrides": {
            "minimatch@<3.1.3": "^3.1.3",
            "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
            "ajv@<6.14.0": "^6.14.0",
            "ajv@>=7.0.0-alpha.0 <8.18.0": "^8.18.0",
            "rollup@>=4.0.0 <4.59.0": "^4.59.0",
            "diff@>=6.0.0 <8.0.3": "^8.0.3",
            "ip-address@<=10.1.0": "^10.1.1"
        }
    }
}
