{
    "name": "mongo-query-top",
    "version": "1.0.0",
    "private": true,
    "repository": "https://github.com/rushi/mongo-query-top",
    "description": "Show the current operations on a MongoDB instance in an easy to read table",
    "type": "module",
    "packageManager": "pnpm@10.8.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev --filter=@mongo-query-top/web --filter=@mongo-query-top/api",
        "dev:api": "turbo dev --filter=@mongo-query-top/api",
        "start": "concurrently \"pnpm start:api\" \"pnpm start:web\"",
        "start:api": "pnpm --filter=@mongo-query-top/api start",
        "start:web": "pnpm --filter=@mongo-query-top/web start",
        "format": "prettier -l --write \"**/*.{ts,tsx,json,md}\"",
        "lint": "turbo lint",
        "clean": "turbo clean && rm -rf node_modules"
    },
    "keywords": [
        "mongodb",
        "top"
    ],
    "author": "Rushi Vishavadia <rushi@hey.com>",
    "license": "MIT",
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
        "@types/node": "^25.0.3",
        "@typescript-eslint/eslint-plugin": "^8.51.0",
        "@typescript-eslint/parser": "^8.51.0",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.2",
        "prettier": "^3.7.4",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "turbo": "^2.7.2",
        "typescript": "^5.9.3"
    }
}
